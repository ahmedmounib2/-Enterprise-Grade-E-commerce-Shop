# API Configuration
VITE_API_BASE_URL=https://localhost:5001
VITE_CLIENT_BASE_URL=https://localhost:5173
VITE_API_TIMEOUT_MS=30000
VITE_KEEPALIVE_INTERVAL_MS=300000

# Stripe (Frontend)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Sentry (Frontend Error Monitoring)
VITE_SENTRY_DSN=
VITE_SENTRY_RELEASE=frontend@git_commit_sha
VITE_SENTRY_TRACES_SAMPLE_RATE=0.1

# Tax and Shipping (Frontend)
VITE_TAX_RATE=0.14
VITE_SHIPPING_COST=70

# Google Analytics 4
# Set to your GA4 Measurement ID. Embedded at build time by Vite.
# Get it from: GA4 → Admin → Data Streams → your stream → Measurement ID
VITE_GA_ID=G-XXXXXXXXXX

# Google Maps
VITE_GOOGLE_MAPS_API_KEY=

# Feature Flags
VITE_FEATURE_CATEGORY_TREE_V2=true
VITE_FEATURE_NAV_CATEGORY_MENU_V2=true
VITE_FEATURE_SELLER_KYC=true
VITE_ADMIN_AUDIT_DASHBOARD=true
VITE_FEATURE_SERVICES_PAGE=true
VITE_FEATURE_CASE_STUDIES_PAGE=true
VITE_FEATURE_ARCHITECTURE_PAGE=true
VITE_FEATURE_WEBSITE_CATALOGUE_TWO=true

FRONTEND_URL=https://localhost:5173
SELLER_DASHBOARD_URL=https://localhost:5173
