# backend/.env.example
# Copy this file to .env and fill in values before starting the server.
#
# Legend:
#   REQUIRED IN PRODUCTION  — must be set or the server fails to start / behaves insecurely.
#   optional                — a sensible default exists; override only when needed.
#   DEV / PRODUCTION blocks — cron-job sections show both a fast dev schedule and a
#                             safe production schedule (production values are commented out).

# ─── Deployment / Networking ──────────────────────────────────────────────────

# Runtime environment: "development" | "test" | "production"
NODE_ENV=development

# TCP port the Express server binds to. (optional; default: 5001)
PORT=5001

# Public base URL of this API server — no trailing slash.
# REQUIRED IN PRODUCTION
SERVER_URL=https://localhost:5001

# Production set to https://api.ahmedmonib-eshop-demo.com

# Public base URL of the web frontend.
# Used for CORS allow-list, email confirmation links, and OAuth redirects.
# REQUIRED IN PRODUCTION
CLIENT_URL=https://localhost:5173
CLIENT_WEB_URL=https://localhost:5173
CLIENT_PUBLIC_URL=https://localhost:5173
FRONTEND_URL=https://localhost:5173

# Canonical production origin used for security headers and CSP.
# REQUIRED IN PRODUCTION
PRODUCTION_ORIGIN=https://www.ahmedmonib-eshop-demo.com

# Comma-separated origins permitted in development (NODE_ENV=development only).
# Supports multiple values: https://localhost:5173,https://localhost:3000
DEV_ORIGIN=https://localhost:5173,https://localhost:3000

# Domain for Set-Cookie. In production use the apex domain so subdomains share the cookie.
# Example: .ahmedmonib-eshop-demo.com — leave blank for localhost dev.
COOKIE_DOMAIN=

# Number of trusted reverse-proxy hops between the CDN/edge and this server.
# 1 = Railway/Render reverse proxy only. 2 = CDN (Cloudflare) → proxy → app.
# Miscounting breaks IP-based rate-limiting buckets.
# REQUIRED IN PRODUCTION (default: 1)
TRUST_PROXY=1

# BCP 47 locale tag used as the fallback locale. (optional; default: en)
DEFAULT_LOCALE=en

# Set "true" to use an HTML meta-refresh redirect instead of HTTP 302 for some
# mobile OAuth flows — helps with certain WebView redirect handling issues.
# (optional; default: false)
USE_HTML_REDIRECT=false

# Fallback URL sent to the client when no referrer can be determined.
PUBLIC_CLIENT_FALLBACK_URL=https://www.ahmedmonib-eshop-demo.com

# Absolute path to the .env file dotenv should load (overrides default lookup).
# (optional; leave blank to use the default .env in the project root)
DOTENV_CONFIG_PATH=

# Override the package path for @eshop/locales when running in containers.
# (optional)
SHARED_LOCALES_PATH=

# ─── MongoDB ──────────────────────────────────────────────────────────────────

# REQUIRED IN PRODUCTION
# Full MongoDB connection string (Atlas or self-hosted).
# Format: mongodb+srv://<user>:<pass>@<host>/<dbname>?retryWrites=true&w=majority
MONGO_URI=

# Force-sync Order collection indexes on startup.
# NEVER set in production — use the sync:order-indexes npm script instead.
# (optional; default: false)
SYNC_ORDER_INDEXES=false

# ─── Redis / Upstash ──────────────────────────────────────────────────────────

# Cache/auth/session driver override: "rest" (Upstash REST) | "tcp" (ioredis).
# Leave blank for auto-detection (prefers REST when UPSTASH_REDIS_REST_URL is set).
REDIS_DRIVER=rest

# Upstash REST driver — stateless, works on serverless/edge runtimes.
# Use these for cache, auth-token storage, stock locks, etc.
# REQUIRED IN PRODUCTION (if using Upstash REST driver)
UPSTASH_REDIS_REST_URL=https://<your-upstash-instance>.upstash.io
UPSTASH_REDIS_REST_TOKEN=

# ioredis TCP connection string — used when REDIS_DRIVER=tcp.
# Format: redis://:password@host:port  or  rediss://... for TLS
REDIS_URL=redis://localhost:6379

# Legacy Upstash TCP-compatible URL (falls back to REDIS_URL if not set). (optional)
UPSTASH_REDIS_URL=

# Dedicated Redis for express-session (optional; falls back to REDIS_URL).
# In dev, a local Redis instance avoids polluting the Upstash REST cache with sessions.
SESSION_REDIS_URL=redis://127.0.0.1:6379

# Key prefix for all session keys stored in Redis. (optional; default: eshop:sess:)
SESSION_REDIS_PREFIX=session:dev:

# ─── Auth / JWT / CSRF ────────────────────────────────────────────────────────

# REQUIRED IN PRODUCTION
# Secret for signing express-session cookies.
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=

# REQUIRED IN PRODUCTION
# HMAC secret for CSRF token signing. Must be distinct from SESSION_SECRET.
# Rotating CSRF_SECRET invalidates all outstanding CSRF tokens but does
# NOT affect active sessions. Rotate CSRF first, redeploy, then rotate
# SESSION_SECRET so users are not bounced twice.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CSRF_SECRET=

# REQUIRED IN PRODUCTION
# HMAC-SHA256 secret for signing access (short-lived) JWT tokens.
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
ACCESS_TOKEN_SECRET=

# Access token TTL — any value accepted by the ms / jsonwebtoken library.
# (optional; default: 15m)
ACCESS_TOKEN_EXPIRE=15m

# REQUIRED IN PRODUCTION
# HMAC-SHA256 secret for signing refresh tokens (stored in Redis; httpOnly cookie).
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
REFRESH_TOKEN_SECRET=

# Refresh token TTL — controls JWT exp, cookie maxAge, and Redis key TTL simultaneously.
# Changing this value affects all three. Keep them in sync by only setting it here.
# (optional; default: 30d)
REFRESH_TOKEN_EXPIRE=30d

# Legacy JWT secret alias used by some helpers — prefer ACCESS_TOKEN_SECRET for new code.
JWT_SECRET=

# Set "true" to emit detailed refresh-token lifecycle logs (dev/debug only). (optional)
DEBUG_REFRESH=false

# TTL in minutes for email OTP / verification codes. (optional; default: 15)
VERIFICATION_CODE_TTL_MIN=15

# Server-enforced maximum session lifetime in days. (optional; default: 30)
MAX_SESSION_LIFETIME_DAYS=30

# ─── OAuth / Social Login ─────────────────────────────────────────────────────

# Google OAuth 2.0 — create credentials at console.cloud.google.com.
# REQUIRED IN PRODUCTION (if Google sign-in is enabled)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://localhost:5001/api/auth/google/callback
GOOGLE_LINK_CALLBACK_URL=https://localhost:5001/api/auth/google/link/callback

# Facebook OAuth — create an app at developers.facebook.com.
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_CALLBACK_URL=https://localhost:5001/api/auth/facebook/callback
FACEBOOK_LINK_CALLBACK_URL=https://localhost:5001/api/auth/facebook/link/callback

# REQUIRED IN PRODUCTION
# HMAC key for one-shot OAuth bridge codes used in mobile deep-link callbacks (C-3/C-4 fix).
# Replaces tokens-in-URL; must be distinct from MOBILE_DASHBOARD_BRIDGE_SECRET and all JWT secrets.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
OAUTH_BRIDGE_SECRET=

# Bridge code TTL in seconds. Values below ~30s may cause UX issues on slow mobile networks.
# (optional; default: 120)
OAUTH_BRIDGE_TTL_SECONDS=120

# Deep-link URI scheme registered in the mobile app (must match app.json / AndroidManifest).
MOBILE_OAUTH_REDIRECT_URI=eshop://oauth

# Deep-link URI for password-reset flow on mobile.
MOBILE_RESET_REDIRECT_URI=eshop://reset-password

# ─── Stripe Payments ──────────────────────────────────────────────────────────

# Reserved for future multi-gateway support — not currently read by the application.
# Stripe is always the active payment gateway. (optional; reserved)
PAYMENT_PROVIDER=stripe

# REQUIRED IN PRODUCTION
# Stripe secret key. Use sk_test_*** in dev, sk_live_*** in production.
STRIPE_SECRET_KEY=

# REQUIRED IN PRODUCTION
# Webhook signing secret — copy from "stripe listen" output or the Stripe dashboard.
STRIPE_WEBHOOK_SECRET=

# Optional comma-separated additional webhook signing secrets for zero-downtime rotation.
# Add a new secret here alongside the old STRIPE_WEBHOOK_SECRET while rotating.
# Example: STRIPE_WEBHOOK_SECRETS=whsec_new,whsec_old
STRIPE_WEBHOOK_SECRETS=

# Stripe Price ID for the seller Pro subscription plan.
STRIPE_PRO_PRICE_ID=

# ISO 3166-1 alpha-2 country code for Stripe Connect account creation.
# (optional; default: US)
STRIPE_CONNECT_COUNTRY=US

# Stripe percentage fee expressed as a PLAIN PERCENT (e.g. 2.9 means 2.9 %, not 0.029).
# (optional; default: 2.9)
STRIPE_PERCENT_FEE=2.9

# Stripe fixed per-transaction fee in cents (e.g. 30 = $0.30).
# (optional; default: 30)
STRIPE_FIXED_FEE_CENTS=30

# Source of truth for Stripe fee data when calculating payout/refund estimates.
# "balance_transaction" — uses real Stripe balance-tx data when available (recommended).
# "platform"            — uses STRIPE_PERCENT_FEE / STRIPE_FIXED_FEE_CENTS estimates only.
# (optional; default: balance_transaction)
STRIPE_FEE_SOURCE=balance_transaction

# ─── Chimoney / COD Payouts ───────────────────────────────────────────────────

# COD payout provider: "chimoney" | "stripe" | "manual".
# (optional; default: chimoney)
COD_PAYOUT_PROVIDER=chimoney

# Adapter class override for the COD payout driver (leave blank to use the provider default).
COD_PAYOUT_ADAPTER=chimoney

# Chimoney API base URL.
# DEV:  sandbox endpoint (https://api-v2-sandbox.chimoney.io/v0.2.4)
# PROD: production endpoint (https://api.chimoney.io)
CHIMONEY_BASE_URL=https://api-v2-sandbox.chimoney.io/v0.2.4

# REQUIRED IN PRODUCTION (if COD_PAYOUT_PROVIDER=chimoney)
CHIMONEY_API_KEY=

# REQUIRED IN PRODUCTION (if Chimoney webhooks are enabled)
# HMAC secret for validating incoming Chimoney webhook callbacks.
CHIMONEY_WEBHOOK_SECRET=

# URL path template to check payout status (appended to CHIMONEY_BASE_URL).
# {payoutId} is replaced at runtime with the actual payout identifier.
# DEV (sandbox):  /payouts/{payoutId}
# PROD:           /payouts/{payoutId}   (same; verify against Chimoney API docs for your version)
CHIMONEY_PAYOUT_STATUS_PATH=/payouts/{payoutId}

# Maximum retries for transient Chimoney API failures. (optional; default: 3)
CHIMONEY_MAX_RETRIES=3

# Base delay in ms between retries; exponential back-off applied on top. (optional; default: 500)
CHIMONEY_RETRY_BASE_DELAY_MS=500

# Reserved for future use — not currently read by the application. (optional; reserved)
CHIMONEY_SOURCE_CURRENCY=USD

# HTTP timeout for Chimoney API requests in ms. (optional; default: 10000)
CHIMONEY_TIMEOUT_MS=10000

# Max request body size for incoming Chimoney webhook payloads. (optional; default: 1mb)
CHIMONEY_WEBHOOK_BODY_LIMIT=1mb

# ISO 4217 currency for COD wallet balances. (optional; default: USD)
COD_BALANCE_CURRENCY=USD

# Default ISO 4217 currency for COD refunds. (optional; default: USD)
COD_REFUND_DEFAULT_CURRENCY=USD

# Comma-separated required FIELD NAMES customers must submit for bank refunds (schema, not values).
# Adjust to match your region/compliance requirements.
COD_BANK_FIELDS=countryCode,routingNumber,accountNumber,accountHolderName

# Comma-separated required fields for wallet/mobile-money refunds (schema, not platform values).
COD_WALLET_FIELDS=walletProvider,walletId

# Minimum balance in cents before a seller is blocked from new COD orders.
# Use a negative value (e.g. -10000 = -$100.00). (optional; default: -10000)
COD_NEGATIVE_BALANCE_THRESHOLD_CENTS=-10000

# Hours between "negative balance" block notification emails per seller. (optional; default: 48)
COD_BLOCK_NOTIFY_COOLDOWN_HOURS=48

# COD refund delivery method: "bank_transfer" | "wallet" | "chimoney" | "stripe" | "manual".
COD_REFUND_METHOD=bank_transfer

# Days submitted refund payout details stay valid before re-collection is required.
# DEV:  1   (expire quickly for fast iteration)
# PROD: 30  (enough time for async payout processing)
COD_REFUND_DETAILS_TTL_DAYS=1

# REQUIRED IN PRODUCTION (if COD refund detail encryption is enabled)
# AES-256-GCM key for encrypting stored bank/wallet refund details.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
COD_REFUND_DETAILS_ENCRYPTION_KEY=

# Comma-separated older keys for zero-downtime key rotation (newest stays in COD_REFUND_DETAILS_ENCRYPTION_KEY).
COD_REFUND_DETAILS_ENCRYPTION_KEYS=

# Set "true" to store raw Chimoney webhook bodies in logs (dev/debug only — NEVER in prod).
COD_REFUND_CHIMONEY_WEBHOOK_STORE_RAW_DEBUG=false

# --- COD reconciliation cron ---
# DEV — fast iteration (every 1 minute, age threshold 1 minute):
COD_PAYOUT_RECONCILIATION_ENABLED=true
# Set to 'true' to fire one immediate run on server start (only safe on single-replica deploys).
COD_PAYOUT_RECONCILIATION_RUN_ON_BOOT=false
COD_PAYOUT_RECONCILIATION_CRON=*/1 * * * *
COD_PAYOUT_RECONCILIATION_TIMEZONE=UTC
COD_PAYOUT_RECONCILIATION_AGE_MINUTES=1

# PRODUCTION — every 20 minutes, 45-minute age threshold:
# COD_PAYOUT_RECONCILIATION_ENABLED=true
# COD_PAYOUT_RECONCILIATION_CRON=*/20 * * * *
# COD_PAYOUT_RECONCILIATION_TIMEZONE=UTC
# COD_PAYOUT_RECONCILIATION_AGE_MINUTES=45

# COD refund purge cron (removes expired refund detail records).
# (optional; default: daily at 04:00 UTC)
COD_REFUND_PURGE_CRON=0 4 * * *
COD_REFUND_PURGE_TZ=UTC

# ─── Email (SendGrid / Resend) ────────────────────────────────────────────────
# Configure SendGrid OR Resend — the mailer auto-selects based on which key is set.
# REQUIRED IN PRODUCTION (at least one provider must be fully configured)

# SendGrid API key (starts with SG.).
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=orders@email.ahmedmonib-eshop-demo.com
SENDGRID_FROM_NAME="Ecommerce store"

# Resend API key (starts with re_).
RESEND_API_KEY=
RESEND_FROM_EMAIL=orders@email.ahmedmonib-eshop-demo.com
RESEND_FROM_NAME="Ecommerce store"

# Support inbox shown in transactional email footers.
SUPPORT_EMAIL=support@email.ahmedmonib-eshop-demo.com
SUPPORT_BCC_EMAIL=
SUPPORT_FROM_NAME=eShop Support

# ─── Cloudinary / File Uploads ────────────────────────────────────────────────

# REQUIRED IN PRODUCTION
# Credentials from Cloudinary Dashboard → Settings → API Keys.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Cloudinary folder for product images. (optional; default: products)
CLOUDINARY_FOLDER=products

# Cloudinary folder for category images. (optional; default: categories)
CLOUDINARY_CATEGORY_FOLDER=categories

# Cloudinary folder for seller KYC documents.
# Keep separate from products for access-control clarity. (optional; default: kyc_documents)
CLOUDINARY_KYC_FOLDER=kyc_documents

# Base directory for local uploads before being pushed to Cloudinary.
UPLOADS_BASE_DIR=uploads

# Sub-directory under UPLOADS_BASE_DIR for category images.
CATEGORY_IMAGES_DIR=uploads/categories

# Sub-directory under UPLOADS_BASE_DIR for product images.
PRODUCT_IMAGES_DIR=products

# Maximum file size in MB per uploaded file.
# DEV: 50 MB (permissive for testing large assets)
# PROD: 10 MB (tighter limit reduces abuse surface)
MAX_UPLOAD_MB=50

# Maximum number of files per upload request.
# DEV: 300 (unrestricted for bulk testing)
# PROD: 10  (reasonable per-request cap)
MAX_UPLOAD_FILES=300

# Maximum file size in MB for KYC document uploads. (optional; default: 10)
KYC_UPLOAD_MAX_MB=10

# Days to retain KYC documents in Cloudinary after a decision is made. (optional; default: 365)
KYC_DOCUMENT_RETENTION_DAYS=365

# ─── Tax & Shipping ───────────────────────────────────────────────────────────
# Backend-side tax and shipping values used for server-rendered totals and order validation.
# Keep in sync with the VITE_TAX_RATE / VITE_SHIPPING_COST frontend build vars below.

# Tax rate as a decimal fraction (e.g. 0.14 = 14 %).
TAX_RATE=0.14

# Flat shipping cost in your platform currency's major unit (e.g. 70 = $70 or 70 EGP).
SHIPPING_COST=70

# ─── Sentry / Observability ───────────────────────────────────────────────────

# DSN from your Sentry project settings. Leave blank to disable Sentry entirely.
SENTRY_DSN=

# Release identifier sent to Sentry (e.g. "backend@<git-sha>").
# CI usually populates this automatically.
SENTRY_RELEASE=backend@git_commit_sha

# Fraction of transactions sampled for Sentry performance monitoring (0.0–1.0).
# (optional; default: 0.1)
SENTRY_TRACES_SAMPLE_RATE=0.1

# REQUIRED IN PRODUCTION
# Bearer token protecting the /api/monitoring/metrics Prometheus scrape endpoint.
# If not set in production, the endpoint returns 404.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MONITORING_METRICS_TOKEN=

# Git commit SHA injected at deploy time (CI sets this). (optional)
GIT_SHA=

# Semantic version string used in Sentry release tagging. (optional)
APP_VERSION=

# ─── Feature Flags ────────────────────────────────────────────────────────────
# All flags are env-var driven: "true" enables; any other value (or unset) disables.

# Set to true to enable the multi-seller marketplace. When unset,
# /api/seller/*, /api/sellers/*, /api/stores/*, and
# /api/public/stores/* routes are all DISABLED.
FEATURE_MULTI_SELLER=true
FEATURE_SELLER_KYC=true
FEATURE_SELLER_ORDERS=true
FEATURE_CATEGORY_TREE_V2=true
FEATURE_MOBILE_CATEGORY_TREE_V2=false

# Passed to mobile clients via the backend feature-flag API response.
EXPO_PUBLIC_FEATURE_MOBILE_CATEGORY_TREE_V2=false

# ─── Subscription Renewal Cron ────────────────────────────────────────────────
# Attempts to charge sellers for upcoming subscription renewals.

SUBSCRIPTION_RENEWAL_ENABLED=true
# Set to 'true' to fire one immediate run on server start (only safe on single-replica deploys).
SUBSCRIPTION_RENEWAL_RUN_ON_BOOT=false

# DEV — every minute so changes are visible immediately:
SUBSCRIPTION_RENEWAL_CRON=* * * * *
SUBSCRIPTION_RENEWAL_TZ=UTC
# Only attempt renewals at/after expiry (lookahead 0 so test subscriptions trigger immediately).
SUBSCRIPTION_RENEWAL_LOOKAHEAD_DAYS=0
# Few retries so the downgrade path is reached quickly during testing.
SUBSCRIPTION_RENEWAL_MAX_RETRIES=2
# ~1-minute retry interval (0.016 h ≈ 1 min) for fast dev feedback.
SUBSCRIPTION_RENEWAL_RETRY_DELAY_HOURS=0.016
# ~2-minute grace period (0.032 h ≈ 2 min) before downgrading.
SUBSCRIPTION_RENEWAL_DOWNGRADE_GRACE_HOURS=0.032

# PRODUCTION — hourly sweep, 3-day lookahead, 12-hour retry spacing, 24-hour grace:
# SUBSCRIPTION_RENEWAL_CRON=0 * * * *
# SUBSCRIPTION_RENEWAL_TZ=UTC
# SUBSCRIPTION_RENEWAL_LOOKAHEAD_DAYS=3
# SUBSCRIPTION_RENEWAL_MAX_RETRIES=3
# SUBSCRIPTION_RENEWAL_RETRY_DELAY_HOURS=12
# SUBSCRIPTION_RENEWAL_DOWNGRADE_GRACE_HOURS=24

# Payment grace period: days a seller stays on Pro after a card failure before auto-downgrade.
# Set to false to disable grace period and fall back to retry/downgrade logic for card errors.
PAYMENT_GRACE_PERIOD_DAYS=7
PAYMENT_GRACE_ENABLED=true

# TTL in minutes for one-time subscription confirmation tokens. (optional; default: 60)
SUBSCRIPTION_TOKEN_TTL_MIN=60

# ─── Reserve Release Cron ─────────────────────────────────────────────────────
# Releases seller payment reserves to available balance once the hold period expires.

RESERVE_RELEASE_JOB_ENABLED=true

# DEV — every 2 minutes, 0-day hold so reserves release immediately for testing:
RESERVE_RELEASE_CRON=*/2 * * * *
RESERVE_RELEASE_TZ=UTC
RESERVE_MIN_HOLD_DAYS=0

# PRODUCTION — daily at 02:00 UTC, 14-day hold (common industry standard):
# RESERVE_RELEASE_CRON=0 2 * * *
# RESERVE_RELEASE_TZ=UTC
# RESERVE_MIN_HOLD_DAYS=14

# Max records processed per job run to cap database load. (optional; default: 500)
RESERVE_RELEASE_BATCH_LIMIT=500

# Reserve percentage tiers — expressed as PLAIN INTEGERS (e.g. 10 = 10 %, not 0.10).
# DEV (fast test cycle):
RESERVE_PERCENTAGE_NEW=10
RESERVE_PERCENTAGE_ESTABLISHED=5
RESERVE_PERCENTAGE_PRO=2
RESERVE_PERCENTAGE_HIGH_RISK=20
DEFAULT_RESERVE_TIER=new
DEFAULT_RESERVE_PERCENTAGE_NEW=10
# Fallback when no tier matches. (optional)
RESERVE_PERCENTAGE_DEFAULT=10

# PRODUCTION (tighter holds for risk management):
# RESERVE_PERCENTAGE_NEW=15
# RESERVE_PERCENTAGE_ESTABLISHED=5
# RESERVE_PERCENTAGE_PRO=2
# RESERVE_PERCENTAGE_HIGH_RISK=25
# DEFAULT_RESERVE_TIER=new
# DEFAULT_RESERVE_PERCENTAGE_NEW=15
# RESERVE_PERCENTAGE_DEFAULT=10

# ─── Settlement Policy ────────────────────────────────────────────────────────
# Controls the settlement cycle: how long to hold funds and when to disburse.

SETTLEMENT_SCHEDULER_ENABLED=true
SETTLEMENT_CURRENCY=USD

# DEV — fast manual-testing cycle (1-day period, 0-day hold, every 2 minutes):
SETTLEMENT_PERIOD_DAYS=1
SETTLEMENT_HOLD_DAYS=0
SETTLEMENT_CRON=*/2 * * * *
SETTLEMENT_TZ=Africa/Cairo
SETTLEMENT_SCHEDULER_TZ=UTC
# false = calculate only; no real payouts are triggered during dev.
SETTLEMENT_AUTO_EXECUTE=false

# PRODUCTION — 15-day cycle, 0-day hold, daily midnight run:
# SETTLEMENT_PERIOD_DAYS=15
# SETTLEMENT_HOLD_DAYS=0
# SETTLEMENT_CRON=0 0 * * *
# SETTLEMENT_TZ=Africa/Cairo
# SETTLEMENT_SCHEDULER_TZ=UTC
# SETTLEMENT_AUTO_EXECUTE=true

# ─── Settlement Payout Retry Cron ─────────────────────────────────────────────
# Retries settlement payouts that failed in a previous run.

SETTLEMENT_PAYOUT_RETRY_ENABLED=true
# Set to 'true' to fire one immediate run on server start (only safe on single-replica deploys).
PAYOUT_RETRY_RUN_ON_BOOT=false

# DEV — every 2 minutes, 2 retries (reaches manual_required quickly):
SETTLEMENT_PAYOUT_RETRY_CRON=*/2 * * * *
SETTLEMENT_PAYOUT_RETRY_MAX_RETRIES=2

# PRODUCTION — twice an hour (15 min and 45 min past), 3 retries:
# SETTLEMENT_PAYOUT_RETRY_CRON=15,45 * * * *
# SETTLEMENT_PAYOUT_RETRY_MAX_RETRIES=3

# ─── Settlement Reconciliation Cron ───────────────────────────────────────────
# Scans recent settlements for discrepancies and emails a report.

SETTLEMENT_RECONCILIATION_ENABLED=true
# Set to 'true' to fire one immediate run on server start (only safe on single-replica deploys).
SETTLEMENT_RECONCILIATION_RUN_ON_BOOT=false

# DEV — every 15 minutes, scan last 1 day only:
SETTLEMENT_RECONCILIATION_CRON=*/15 * * * *
SETTLEMENT_RECONCILIATION_TIMEZONE=UTC
SETTLEMENT_RECONCILIATION_SCAN_DAYS=1

# PRODUCTION — nightly at 02:15 UTC, scan last 2 days:
# SETTLEMENT_RECONCILIATION_CRON=15 2 * * *
# SETTLEMENT_RECONCILIATION_TIMEZONE=UTC
# SETTLEMENT_RECONCILIATION_SCAN_DAYS=2

# Recipients for the reconciliation report email.
SETTLEMENT_RECONCILIATION_REPORT_TO=admin
SETTLEMENT_RECONCILIATION_REPORT_EMAILS=
SETTLEMENT_RECONCILIATION_REPORT_ROLES=admin,staff
# Maximum number of admin email recipients for the reconciliation report (prevents unbounded fan-out).
SETTLEMENT_RECONCILIATION_MAX_REPORT_RECIPIENTS=5

# ─── Settlement Distributed Lock ──────────────────────────────────────────────
# Prevents duplicate settlement runs across multiple instances.

# DEV — dev-namespaced key, short TTL, unlock if Redis is unavailable:
SETTLEMENT_LOCK_KEY=lock:settlement_scheduler:dev
SETTLEMENT_LOCK_TTL_SECONDS=120
# "run_unlocked" = proceed even if Redis lock fails (safe for single-instance dev only).
SETTLEMENT_LOCK_REDIS_FALLBACK_POLICY=run_unlocked

# PRODUCTION — shared key, 5-minute TTL, skip cycle on lock failure:
# SETTLEMENT_LOCK_KEY=lock:settlement_scheduler
# SETTLEMENT_LOCK_TTL_SECONDS=300
# "skip_cycle" = skip this run if Redis lock cannot be acquired (safest for financial jobs).
# SETTLEMENT_LOCK_REDIS_FALLBACK_POLICY=skip_cycle

# STAGING — prod-like behaviour, isolated keyspace:
# SETTLEMENT_LOCK_KEY=lock:settlement_scheduler:staging
# SETTLEMENT_LOCK_TTL_SECONDS=300
# SETTLEMENT_LOCK_REDIS_FALLBACK_POLICY=skip_cycle

# ─── Job Health Monitoring ────────────────────────────────────────────────────
# Thresholds for alerting on stale schedulers and high payout-failure rates.

# Hours of silence before a scheduler is flagged as "stale" (not ticking).
# DEV:  1   (surface stale-scheduler bugs quickly)
# PROD: 24  (less noisy; a daily cron firing once per 24 h is healthy)
JOB_HEALTH_SCHEDULER_STALE_HOURS=1

# Failure rate (0.0–1.0) over recent payout-retry runs that triggers an alert.
# DEV:  0.8  (only alert on near-total failure — avoid noise during testing)
# PROD: 0.3  (alert early; 30 % failure rate is already a production concern)
JOB_HEALTH_PAYOUT_FAILURE_RATE_THRESHOLD=0.8

# Rolling window size (number of recent runs) used for the failure-rate calculation.
# DEV:  10
# PROD: 20–50 (larger window smooths out transient spikes)
JOB_HEALTH_PAYOUT_FAILURE_WINDOW_RUNS=10

# Minimum number of completed runs required before failure-rate alerting activates.
# DEV:  3
# PROD: 5–10
JOB_HEALTH_PAYOUT_FAILURE_MIN_RUNS=3

# Optional: Slack incoming webhook URL for critical job-health alerts (staleness, failure rate).
# Leave empty to disable Slack notifications.
OPS_SLACK_WEBHOOK=

# ─── Field-level Encryption / GDPR ───────────────────────────────────────────

# REQUIRED IN PRODUCTION
# AES-256-GCM key for encrypting PII and banking data at rest.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
FIELD_ENCRYPTION_KEY=

# Comma-separated older keys for zero-downtime key rotation.
# Newest key stays in FIELD_ENCRYPTION_KEY; older keys listed here so existing records decrypt.
FIELD_ENCRYPTION_KEYS=

# Days after soft-delete before the purge script hard-deletes the user record.
# Adjust per jurisdiction (e.g. 30 days satisfies most GDPR right-to-erasure obligations).
# (optional; default: 30)
USER_DELETION_RETENTION_DAYS=30

# Redis lock TTL in seconds for refund operations (prevents duplicate refund execution).
# (optional; default: 30)
REFUND_LOCK_TTL_SECONDS=30

# Rate-limiting window duration in milliseconds.
# DEV:  3600000 (1 hour — high limits for easy local testing)
# PROD: 900000  (15 minutes — tighter window reduces abuse exposure)
RATE_WINDOW_MS=3600000

# ─── Rate Limiting ────────────────────────────────────────────────────────────
# Per-window request caps applied to admin and seller routes.
# DEV values are intentionally high to avoid interrupting local testing.

# Admin route limits
# DEV:  10000 / 10000 / 10000   PROD: 200 / 100 / 50
ADMIN_REQ_LIMIT=10000
ADMIN_READ_LIMIT=10000
ADMIN_WRITE_LIMIT=10000

# Seller route limits
# DEV:  1000 / 1000 / 1000   PROD: 300 / 200 / 100
SELLER_REQ_LIMIT=1000
SELLER_READ_LIMIT=1000
SELLER_WRITE_LIMIT=1000

# ─── Mobile / Deep Links ──────────────────────────────────────────────────────

# REQUIRED IN PRODUCTION
# HMAC key for the one-time mobile→web dashboard bridge token.
# Must be distinct from ACCESS_TOKEN_SECRET.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MOBILE_DASHBOARD_BRIDGE_SECRET=

# TTL in seconds for the mobile dashboard bridge token. (optional; default: 300)
MOBILE_DASHBOARD_BRIDGE_TTL_SECONDS=300

# Deep-link URI for the email-confirmation flow on mobile.
MOBILE_MAIL_CONFIRM_URI=eshop://mailing/confirm

# Web-side URL the backend rewrites to when confirming an email via the mobile bridge.
# In dev point to your local server or ngrok tunnel.
MAIL_CONFIRM_WEB_URL=https://localhost:5001/api/mailing/confirm
MAIL_CONFIRM_REDIRECT_URL=
MAIL_CONFIRM_BRIDGE_URL=

# REQUIRED IN PRODUCTION
# Secret for signing short-lived seller KYC document view tokens.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SELLER_DOC_VIEW_TOKEN_SECRET=

# URL of the seller dashboard (used in mobile deep-link redirect targets).
SELLER_DASHBOARD_URL=https://www.ahmedmonib-eshop-demo.com/seller/dashboard

# ─── Platform / Multi-Seller ──────────────────────────────────────────────────

# REQUIRED IN PRODUCTION (if FEATURE_MULTI_SELLER=true)
# MongoDB ObjectId of the platform's own seller account (fee accounting).
PLATFORM_SELLER_ID=
PLATFORM_SELLER_SLUG=admin
PLATFORM_CURRENCY=USD

# MongoDB ObjectId of the shipping provider's seller account.
SHIPPING_SELLER_ID=

# MongoDB ObjectId and display name of the admin / platform store.
ADMIN_STORE_ID=
ADMIN_STORE_NAME=E-Commerce

# Number of days buyers have to request a return after delivery. (optional; default: 14)
ORDER_RETURN_WINDOW_DAYS=14

# ─── Miscellaneous ────────────────────────────────────────────────────────────

# Set "true" to run one-off maintenance scripts without writing to the database.
DRY_RUN=false

# ─── Frontend Build Vars (VITE_* / referenced in backend API responses) ───────
# These are Vite/frontend build-time vars that may also be served via backend
# config endpoints. Keep in sync with TAX_RATE and SHIPPING_COST above.

# Feature flag mirror for the Vite build (keep in sync with FEATURE_CATEGORY_TREE_V2).
VITE_FEATURE_CATEGORY_TREE_V2=true

# Displayed shipping cost in the frontend (major unit, e.g. 70 = $70 or 70 EGP).
VITE_SHIPPING_COST=70

# Displayed tax rate in the frontend as a decimal fraction (0.14 = 14 %).
VITE_TAX_RATE=0.14
